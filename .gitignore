# Obsidian vault config (machine-local — Obsidian rewrites these on every open)
context/.obsidian/

# Python build artifacts (created when running skill-creator/scripts/*.py)
__pycache__/
*.pyc
*.pyo

# Temp slash commands generated by skill-creator/scripts/run_eval.py
# (pattern: <skill-name>-skill-<8-hex-uuid>.md, used to test triggering)
.claude/commands/*-skill-[a-f0-9]*.md

# Skill workspaces — runtime artifacts: eval sets, results, benchmarks, viewer output
# Workspaces are local-only by design; nothing inside should be tracked.
skills/*-workspace/
